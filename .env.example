# ============================================================================
# Aether — template des variables d'environnement
# ============================================================================
# Ce fichier est TRACKÉ en git. Aucun secret ici, uniquement les noms.
#
# Usage :
#   1. cp .env.example .env.local
#   2. Édite .env.local et remplace les <PLACEHOLDER> par tes vraies clés
#   3. .env.local est gitignored — il ne partira jamais sur GitHub
#
# Pour la prod (Edge Functions Supabase) : ces MÊMES variables doivent
# être posées comme "Edge Function Secrets" via le Dashboard Supabase
# (Project Settings → Edge Functions → Add new secret).
# ============================================================================


# --- Alpaca Paper Trading ---
# Source : https://app.alpaca.markets/paper/dashboard/overview → API Keys
# La clé secrète n'est affichée qu'une fois lors de la génération.
ALPACA_API_KEY_ID=<PK_ID_ICI>
ALPACA_API_SECRET_KEY=<SECRET_ICI>
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets


# --- Anthropic (Claude Sonnet) ---
# Source : https://console.anthropic.com/settings/keys
# Format : sk-ant-api03-...
ANTHROPIC_API_KEY=<SK_ANT_ICI>


# --- Financial Modeling Prep (Premium+) ---
# Source : https://site.financialmodelingprep.com/developer/docs → Dashboard
# Utilisée en REST direct ET dans l'URL du MCP FMP côté Edge Functions.
FMP_API_KEY=<FMP_KEY_ICI>
